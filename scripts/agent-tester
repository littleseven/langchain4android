#!/bin/bash
#
# Agent Tester - PC端主导的JSON数据驱动测试脚本
# 用途: PC端读取JSON测试用例，通过adb发送命令给应用执行
# 调用: ./scripts/agent-tester suite camera
#       ./scripts/agent-tester case scripts/tests/camera/tc-camera-02-flip.json
#
# 设计原则:
# - PC端: 负责读取JSON、测试编排、截屏、性能采集、报告生成
# - 应用端: 通过BroadcastReceiver接收命令，CapabilityRegistry分发执行
# - 通信方式: adb shell am broadcast --es json <Agent标准JSON命令>

set -e

PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$PROJECT_ROOT"

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# 参数
COMMAND="${1:-}"
ARG="${2:-}"
WAIT_TIMEOUT=300

# 输出目录
TIMESTAMP=$(date '+%Y%m%d_%H%M%S')
OUTPUT_DIR="$PROJECT_ROOT/scripts/auto_test_output/agent_v2_${TIMESTAMP}"
mkdir -p "$OUTPUT_DIR"

# 截屏目录
SCREENSHOT_DIR="$OUTPUT_DIR/screenshots"
mkdir -p "$SCREENSHOT_DIR"

# 报告文件
REPORT_FILE="$OUTPUT_DIR/report.json"
LOG_FILE="$OUTPUT_DIR/test.log"

# ============================================
# 工具函数
# ============================================

log_info() { echo -e "${BLUE}[INFO]${NC} $1" | tee -a "$LOG_FILE"; }
log_ok() { echo -e "${GREEN}[PASS]${NC} $1" | tee -a "$LOG_FILE"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1" | tee -a "$LOG_FILE"; }
log_fail() { echo -e "${RED}[FAIL]${NC} $1" | tee -a "$LOG_FILE"; }
log_step() { echo -e "${CYAN}[STEP]${NC} $1" | tee -a "$LOG_FILE"; }

check_device() {
    if ! adb devices | grep -q "device$"; then
        log_fail "未检测到连接的设备"
        exit 1
    fi
    local device=$(adb devices | grep "device$" | head -1 | awk '{print $1}')
    log_info "设备: $device"
}

# 截屏并保存到PC端
take_screenshot() {
    local name="$1"
    local path="$SCREENSHOT_DIR/${name}.png"
    local temp_path="/sdcard/picme_test_temp_screenshot.png"
    
    if adb shell screencap -p "$temp_path" > /dev/null 2>&1; then
        adb pull "$temp_path" "$path" > /dev/null 2>&1
        adb shell rm "$temp_path" > /dev/null 2>&1
        echo "$path"
    else
        echo ""
    fi
}

# 发送 JSON 命令到应用（通过显式组件 + --es json）
# Android 12+ 必须使用显式组件发送广播
# PC 端不做任何解析，直接把 JSON 字符串透传给应用端
# 注意：JSON 必须用单引号包裹，防止 adb shell 解释 {} 为 brace expansion
send_json_cmd() {
    local json="$1"
    local receiver="com.picme/.testing.agent.bridge.AgentTestBroadcastReceiver"
    
    adb shell "am broadcast -n '$receiver' -a com.picme.AGENT_TEST --es json '$json'" \
        > /dev/null 2>&1 || true
}

# 兼容旧版命令格式（已废弃，保留用于临时调试）
send_cmd() {
    local cmd="$1"
    local param="${2:-}"
    local receiver="com.picme/.testing.agent.bridge.AgentTestBroadcastReceiver"
    
    if [ -n "$param" ]; then
        adb shell am broadcast -n "$receiver" -a com.mamba.picme.AGENT_TEST \
            --es "cmd" "$cmd" \
            --es "param" "$param" \
            > /dev/null 2>&1 || true
    else
        adb shell am broadcast -n "$receiver" -a com.mamba.picme.AGENT_TEST \
            --es "cmd" "$cmd" \
            > /dev/null 2>&1 || true
    fi
}

# 采集性能数据
collect_perf() {
    log_info "采集性能数据..."
    
    # FPS
    local fps_data=$(adb shell dumpsys gfxinfo com.mamba.picme 2>/dev/null | grep -E "Janky frames|Total frames" | head -5)
    if [ -n "$fps_data" ]; then
        echo "$fps_data" >> "$OUTPUT_DIR/perf_fps.txt"
    fi
    
    # 内存
    local mem_data=$(adb shell dumpsys meminfo com.mamba.picme 2>/dev/null | grep -E "TOTAL PSS|Native Heap|Dalvik Heap" | head -5)
    if [ -n "$mem_data" ]; then
        echo "$mem_data" >> "$OUTPUT_DIR/perf_memory.txt"
    fi
    
    # CPU温度
    local temp_data=$(adb shell "cat /sys/class/thermal/thermal_zone*/temp" 2>/dev/null | head -5)
    if [ -n "$temp_data" ]; then
        echo "$(date '+%Y-%m-%d %H:%M:%S')" >> "$OUTPUT_DIR/perf_temp.txt"
        echo "$temp_data" >> "$OUTPUT_DIR/perf_temp.txt"
    fi
}

# 生成JSON报告
generate_report() {
    local suite_name="$1"
    local total="$2"
    local passed="$3"
    local failed="$4"
    
    local screenshot_count=$(ls "$SCREENSHOT_DIR"/*.png 2>/dev/null | wc -l | tr -d ' ')
    
    cat > "$REPORT_FILE" << EOF
{
    "suiteName": "$suite_name",
    "totalCases": $total,
    "passedCount": $passed,
    "failedCount": $failed,
    "passRate": $(echo "scale=2; $passed / $total * 100" | bc -l 2>/dev/null || echo "100"),
    "timestamp": $(date +%s),
    "outputDir": "$OUTPUT_DIR",
    "screenshots": $screenshot_count,
    "device": "$(adb devices | grep 'device$' | head -1 | awk '{print $1}')"
}
EOF
    
    log_info "报告已生成: $REPORT_FILE"
}

# ============================================
# JSON 测试用例解析与执行
# ============================================

# 执行单个JSON测试用例
run_json_case() {
    local json_file="$1"
    local case_id=$(basename "$json_file" .json)
    
    log_info "执行用例: $case_id"
    
    if [ ! -f "$json_file" ]; then
        log_fail "文件不存在: $json_file"
        return 1
    fi
    
    # 使用python3解析并执行JSON步骤
    # 核心原则：PC端只透传 action JSON，不解析参数；所有命令解析在应用端完成
    if command -v python3 > /dev/null 2>&1; then
        python3 - "$json_file" "$SCREENSHOT_DIR" "$case_id" << 'PYEOF'
import json
import subprocess
import sys
import time

json_file = sys.argv[1]
screenshot_dir = sys.argv[2]
case_id = sys.argv[3]

with open(json_file) as f:
    case = json.load(f)

steps = case.get('steps', [])
print(f"[INFO] 步骤数: {len(steps)}", flush=True)

receiver = 'com.picme/.testing.agent.bridge.AgentTestBroadcastReceiver'

for i, step in enumerate(steps):
    desc = step.get('description', f'Step {i+1}')
    print(f"[STEP] {desc}", flush=True)

    # 1. 执行 action（直接把 action JSON 透传给应用端）
    action = step.get('action')
    if action:
        # PC 端不解析参数，直接把原始 action JSON 字符串传给应用
        action_json = json.dumps(action, separators=(',', ':'), ensure_ascii=False)

        # 注意：必须用单引号包裹 JSON，防止设备端 shell 把 {} 解释为 brace expansion
        # 错误：adb shell am broadcast --es json {"method":"flip_camera"}
        #       会被解释为：method:flip_camera
        # 正确：adb shell "am broadcast ... --es json '{\"method\":\"flip_camera\"}'"
        shell_cmd = (
            f"am broadcast -n '{receiver}' -a com.picme.AGENT_TEST "
            f"--es json '{action_json}'"
        )
        subprocess.run(['adb', 'shell', shell_cmd], capture_output=True)
        print(f"  -> json={action_json}", flush=True)
        time.sleep(0.5)

    # 2. 等待条件（简单等待）
    wait = step.get('wait')
    if wait:
        print(f"  -> wait: {wait.get('condition')}", flush=True)
        time.sleep(2)

    # 3. 延迟
    delay = step.get('delay', 0)
    if delay:
        print(f"  -> delay: {delay}ms", flush=True)
        time.sleep(delay / 1000)

    # 4. 截屏（PC端负责，手机端不方便做文件管理）
    screenshot = step.get('screenshot')
    if screenshot:
        ss_name = f"{case_id}_{screenshot}"
        temp_path = "/sdcard/picme_test_temp_screenshot.png"
        subprocess.run(['adb', 'shell', 'screencap', '-p', temp_path], capture_output=True)
        subprocess.run(['adb', 'pull', temp_path, f"{screenshot_dir}/{ss_name}.png"], capture_output=True)
        subprocess.run(['adb', 'shell', 'rm', temp_path], capture_output=True)
        print(f"  -> screenshot: {ss_name}.png", flush=True)

    # 5. 断言（简单输出，不阻断）
    assertions = step.get('assert', {})
    if assertions:
        for key, expected in assertions.items():
            print(f"  -> assert: {key} == {expected}", flush=True)

    # 步骤间停顿
    if i < len(steps) - 1:
        time.sleep(0.8)

print(f"[PASS] 用例执行完成: {len(steps)}/{len(steps)} 步骤", flush=True)
PYEOF
    else
        log_warn "未安装 python3，跳过JSON解析"
        return 1
    fi
    
    return 0
}

# ============================================
# 测试套件执行
# ============================================

run_camera_suite() {
    log_info "开始执行相机测试套件（JSON驱动）"
    
    local suite_dir="$PROJECT_ROOT/scripts/tests/camera"
    local total=0
    local passed=0
    local failed=0
    
    if [ ! -d "$suite_dir" ]; then
        log_fail "测试目录不存在: $suite_dir"
        return 1
    fi
    
    # 统计用例数
    total=$(ls "$suite_dir"/*.json 2>/dev/null | wc -l | tr -d ' ')
    log_info "发现 $total 个测试用例"
    
    # 启动应用
    adb shell am force-stop com.mamba.picme > /dev/null 2>&1 || true
    sleep 1
    adb logcat -c > /dev/null 2>&1 || true
    adb shell am start -n com.mamba.picme/.MainActivity > /dev/null 2>&1
    sleep 3
    
    # 按顺序执行每个JSON用例
    for json_file in "$suite_dir"/*.json; do
        if [ -f "$json_file" ]; then
            if run_json_case "$json_file"; then
                passed=$((passed + 1))
            else
                failed=$((failed + 1))
            fi
        fi
    done
    
    # 最终性能采集
    collect_perf
    
    # 生成报告
    generate_report "camera" "$total" "$passed" "$failed"
    
    log_ok "测试套件执行完成: $passed/$total 通过"
}

run_settings_suite() {
    log_info "开始执行设置页测试套件（JSON驱动）"
    
    local suite_dir="$PROJECT_ROOT/scripts/tests/settings"
    local total=0
    local passed=0
    local failed=0
    
    if [ ! -d "$suite_dir" ]; then
        log_fail "测试目录不存在: $suite_dir"
        return 1
    fi
    
    total=$(ls "$suite_dir"/*.json 2>/dev/null | wc -l | tr -d ' ')
    log_info "发现 $total 个测试用例"
    
    # 启动应用
    adb shell am force-stop com.mamba.picme > /dev/null 2>&1 || true
    sleep 1
    adb shell am start -n com.mamba.picme/.MainActivity > /dev/null 2>&1
    sleep 2
    
    # 导航到设置页
    send_cmd "navigate_to" "settings"
    sleep 2
    
    # 执行设置页用例
    for json_file in "$suite_dir"/*.json; do
        if [ -f "$json_file" ]; then
            if run_json_case "$json_file"; then
                passed=$((passed + 1))
            else
                failed=$((failed + 1))
            fi
        fi
    done
    
    generate_report "settings" "$total" "$passed" "$failed"
    log_ok "测试套件执行完成: $passed/$total 通过"
}

# ============================================
# 主流程
# ============================================

case "$COMMAND" in
    suite)
        check_device
        case "$ARG" in
            camera)
                run_camera_suite
                ;;
            settings)
                run_settings_suite
                ;;
            *)
                log_fail "未知套件: $ARG"
                echo "可用套件: camera, settings"
                exit 1
                ;;
        esac
        ;;
    case)
        check_device
        if [ -f "$ARG" ]; then
            run_json_case "$ARG"
        else
            log_fail "用例文件不存在: $ARG"
            exit 1
        fi
        ;;
    cmd)
        check_device
        # 直接发送单个JSON命令: ./agent-tester cmd '{"method":"flip_camera","params":{}}'
        send_json_cmd "$ARG"
        log_ok "JSON 命令已发送: $ARG"
        ;;
    *)
        echo "PicMe Agent Tester - PC端主导测试（JSON驱动）"
        echo ""
        echo "用法: ./scripts/agent-tester <command> [arg]"
        echo ""
        echo "Commands:"
        echo "  suite camera         运行相机测试套件"
        echo "  suite settings       运行设置页测试套件"
        echo "  case <json文件>      运行单个JSON用例"
        echo "  cmd <json字符串>     直接发送单个JSON命令"
        echo ""
        echo "示例:"
        echo "  ./scripts/agent-tester suite camera"
        echo "  ./scripts/agent-tester case scripts/tests/camera/tc-camera-02-flip.json"
        echo "  ./scripts/agent-tester cmd '{\"method\":\"flip_camera\",\"params\":{}}'"
        echo "  ./scripts/agent-tester cmd '{\"method\":\"switch_filter\",\"params\":{\"filter\":\"leica_classic\"}}'"
        echo ""
        echo "输出目录: $OUTPUT_DIR"
        exit 0
        ;;
esac

echo ""
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${CYAN}  测试完成${NC}"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo "输出目录: $OUTPUT_DIR"
echo "截屏目录: $SCREENSHOT_DIR"
echo "报告文件: $REPORT_FILE"
