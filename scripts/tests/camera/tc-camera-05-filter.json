{
  "caseId": "TC-CAMERA-05",
  "name": "滤镜切换验证",
  "category": "CAMERA",
  "priority": "P1",
  "steps": [
    {
      "description": "等待相机页面就绪",
      "wait": {"condition": "scene == 'CAMERA'", "timeout": 5000},
      "assert": {"scene": "CAMERA"}
    },
    {
      "description": "应用徕卡经典滤镜",
      "action": {"method": "switch_filter", "params": {"filter": "leica_classic"}},
      "assert": {"commandResult": "success"},
      "delay": 500
    },
    {
      "description": "截屏记录徕卡经典",
      "screenshot": "filter_leica_classic"
    },
    {
      "description": "应用徕卡鲜艳滤镜",
      "action": {"method": "switch_filter", "params": {"filter": "leica_vibrant"}},
      "assert": {"commandResult": "success"},
      "delay": 500
    },
    {
      "description": "截屏记录徕卡鲜艳",
      "screenshot": "filter_leica_vibrant"
    },
    {
      "description": "应用徕卡黑白滤镜",
      "action": {"method": "switch_filter", "params": {"filter": "leica_bw"}},
      "assert": {"commandResult": "success"},
      "delay": 500
    },
    {
      "description": "截屏记录徕卡黑白",
      "screenshot": "filter_leica_bw"
    },
    {
      "description": "重置为无滤镜",
      "action": {"method": "switch_filter", "params": {"filter": "none"}},
      "assert": {"commandResult": "success"},
      "delay": 500
    }
  ]
}
