{
  "caseId": "TC-SETTINGS-05",
  "name": "人脸检测引擎切换验证",
  "category": "SETTINGS",
  "priority": "P1",
  "steps": [
    {
      "description": "导航到设置页",
      "action": {"method": "navigate_to", "params": {"destination": "settings"}},
      "assert": {"commandResult": "success"}
    },
    {
      "description": "等待设置场景就绪",
      "wait": {"condition": "scene == 'SETTINGS'", "timeout": 5000},
      "assert": {"scene": "SETTINGS"}
    },
    {
      "description": "切换到 MediaPipe 引擎",
      "action": {"method": "switch_face_engine", "params": {"engine": "mediapipe"}},
      "assert": {"commandResult": "success"}
    },
    {
      "description": "切换到 MNN 引擎",
      "action": {"method": "switch_face_engine", "params": {"engine": "mnn"}},
      "assert": {"commandResult": "success"}
    },
    {
      "description": "切换到 NCNN 引擎",
      "action": {"method": "switch_face_engine", "params": {"engine": "ncnn"}},
      "assert": {"commandResult": "success"}
    },
    {
      "description": "返回相机页",
      "action": {"method": "navigate_to", "params": {"destination": "camera"}},
      "assert": {"commandResult": "success"}
    },
    {
      "description": "等待相机场景就绪",
      "wait": {"condition": "scene == 'CAMERA'", "timeout": 5000},
      "assert": {"scene": "CAMERA"}
    }
  ]
}
