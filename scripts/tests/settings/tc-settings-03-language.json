{
  "caseId": "TC-SETTINGS-03",
  "name": "语言切换验证",
  "category": "SETTINGS",
  "priority": "P0",
  "steps": [
    {
      "description": "导航到设置页",
      "action": {"method": "navigate_to", "params": {"destination": "settings"}},
      "assert": {"commandResult": "success"}
    },
    {
      "description": "等待设置场景就绪",
      "wait": {"condition": "scene == 'SETTINGS'", "timeout": 5000},
      "assert": {"scene": "SETTINGS"}
    },
    {
      "description": "切换到英文",
      "action": {"method": "change_language", "params": {"language": "en"}},
      "assert": {"commandResult": "success"}
    },
    {
      "description": "切换回中文",
      "action": {"method": "change_language", "params": {"language": "zh"}},
      "assert": {"commandResult": "success"}
    },
    {
      "description": "截屏记录中文界面",
      "screenshot": "language_zh"
    },
    {
      "description": "返回相机页",
      "action": {"method": "navigate_to", "params": {"destination": "camera"}},
      "assert": {"commandResult": "success"}
    }
  ]
}
