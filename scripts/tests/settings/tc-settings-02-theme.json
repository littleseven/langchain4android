{
  "caseId": "TC-SETTINGS-02",
  "name": "主题切换验证",
  "category": "SETTINGS",
  "priority": "P0",
  "steps": [
    {
      "description": "导航到设置页",
      "action": {"method": "navigate_to", "params": {"destination": "settings"}},
      "assert": {"commandResult": "success"}
    },
    {
      "description": "等待设置场景就绪",
      "wait": {"condition": "scene == 'SETTINGS'", "timeout": 5000},
      "assert": {"scene": "SETTINGS"}
    },
    {
      "description": "切换到深色主题",
      "action": {"method": "change_theme", "params": {"theme": "dark"}},
      "assert": {"commandResult": "success"}
    },
    {
      "description": "切换到浅色主题",
      "action": {"method": "change_theme", "params": {"theme": "light"}},
      "assert": {"commandResult": "success"}
    },
    {
      "description": "切换到系统主题",
      "action": {"method": "change_theme", "params": {"theme": "system"}},
      "assert": {"commandResult": "success"}
    },
    {
      "description": "截屏记录系统主题",
      "screenshot": "theme_system"
    },
    {
      "description": "返回相机页",
      "action": {"method": "navigate_to", "params": {"destination": "camera"}},
      "assert": {"commandResult": "success"}
    }
  ]
}
