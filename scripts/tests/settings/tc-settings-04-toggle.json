{
  "caseId": "TC-SETTINGS-04",
  "name": "设置项开关验证",
  "category": "SETTINGS",
  "priority": "P1",
  "steps": [
    {
      "description": "导航到设置页",
      "action": {"method": "navigate_to", "params": {"destination": "settings"}},
      "assert": {"commandResult": "success"}
    },
    {
      "description": "等待设置场景就绪",
      "wait": {"condition": "scene == 'SETTINGS'", "timeout": 5000},
      "assert": {"scene": "SETTINGS"}
    },
    {
      "description": "开启调试UI",
      "action": {"method": "toggle_setting", "params": {"settingKey": "debug_ui", "enabled": true}},
      "assert": {"commandResult": "success"}
    },
    {
      "description": "关闭调试UI",
      "action": {"method": "toggle_setting", "params": {"settingKey": "debug_ui", "enabled": false}},
      "assert": {"commandResult": "success"}
    },
    {
      "description": "开启相机信息预览",
      "action": {"method": "toggle_setting", "params": {"settingKey": "camera_info", "enabled": true}},
      "assert": {"commandResult": "success"}
    },
    {
      "description": "关闭相机信息预览",
      "action": {"method": "toggle_setting", "params": {"settingKey": "camera_info", "enabled": false}},
      "assert": {"commandResult": "success"}
    }
  ]
}
